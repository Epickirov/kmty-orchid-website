# Cache rules — read by both Cloudflare Pages and Netlify.
# HTML always revalidates so edits go live immediately; static assets cache.
/*.html
  Cache-Control: public, max-age=0, must-revalidate
/images/*
  Cache-Control: public, max-age=604800
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
/vendor/*
  Cache-Control: public, max-age=31536000, immutable
